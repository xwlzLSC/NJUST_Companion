# Server binding
HOST=127.0.0.1
PORT=3030

# Public HTTPS origin used in logs/docs
PUBLIC_ORIGIN=https://your-domain.example

# If you are behind Caddy/Nginx, enable trust proxy
TRUST_PROXY=true

# Persistent state directory
APP_STORAGE_DIR=./storage

# Optional sync tuning
AUTO_SYNC_INTERVAL_MS=600000
KEEP_ALIVE_INTERVAL_MS=480000
